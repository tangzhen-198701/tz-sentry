{
  "name": "tz-sentry",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:staged": "lint-staged",
    "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"(packages|apps|demos)/**/*.@(html|js|cjs|mjs|ts|tsx|css|scss|md)\"",
    "commit": "git-cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "cspell lint --no-must-find-files --color --cache --show-suggestions"
    ],
    "**/*.{css,scss,md,html}": [
      "prettier --write",
      "cspell lint --no-must-find-files --color --cache --show-suggestions"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "22.5.5",
    "typescript": "5.9.3",
    "@eslint/js": "9.39.1",
    "globals": "16.5.0",
    "typescript-eslint": "8.48.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "cspell": "9.4.0",
    "cz-git": "1.12.0",
    "commitizen": "4.3.1",
    "fast-glob": "3.3.3",
    "@commitlint/config-conventional": "20.2.0",
    "@commitlint/cli": "20.2.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7"
  }
}
