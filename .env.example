# Copy to a local, ignored environment file and replace every change-me value.
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USERNAME=change-me
CLICKHOUSE_PASSWORD=change-me
CLICKHOUSE_DATABASE=tz_sentry
CLICKHOUSE_EVENT_TABLE=tz_sentry.events

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=change-me
POSTGRES_PASSWORD=change-me
POSTGRES_DATABASE=tz_sentry

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=alerts@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=alerts@example.com
ALERT_EMAIL_TO=alerts@example.com

# Generate independent random values of at least 32 bytes for both secrets.
JWT_SECRET=change-me
JWT_EXPIRES_IN_SECONDS=900
INGEST_SIGNING_SECRET=change-me
INGEST_RATE_LIMIT_PER_MINUTE=600
CORS_ORIGINS=http://localhost:5173
